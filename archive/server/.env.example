# Supabase — from project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# USAJobs API — free at developer.usajobs.gov
USAJOBS_USER_AGENT=your@email.com
USAJOBS_API_KEY=your-usajobs-api-key

# Anthropic (Claude API) — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Portfolio URL (GitHub Pages — enable in repo Settings → Pages, set source to main /docs or /portfolio)
PORTFOLIO_URL=https://yourusername.github.io/recuter/portfolio/

# LinkedIn login for auto-apply. Locally these go in .env (gitignored); in CI add
# them as GitHub Actions secrets. Never commit real values.
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-linkedin-password
